{
  "name": "iris-solana",
  "version": "0.1.0",
  "private": true,
  "description": "Iris: verifiable on-chain receipts for AI agent actions",
  "workspaces": [
    "clients/ts"
  ],
  "scripts": {
    "build": "anchor build",
