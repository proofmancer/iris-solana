# Solana
SOLANA_CLUSTER=devnet
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
RELAYER_KEYPAIR_PATH=~/.config/solana/id.json

# Iris program (replace with `anchor keys list` output after first build)
IRIS_PROGRAM_ID=6Sd4wz6XWU8wKQZjttw6g5uQEJMaf5Juv9gTuC2uXWHm

# Data availability for batched receipt roots.
# Default DA is the Solana ledger (SolanaDaPublisher): the batch blob rides in a
# Memo instruction, no extra chain, no TIA, no rent. Nothing to configure here.
DA_BATCH_SIZE=64
DA_FLUSH_INTERVAL_MS=15000

# Optional Phase-2 scale path: Celestia (mocha-4 testnet). Only needed if you
# switch the DA worker to CelestiaPublisher for very large batches. Requires a
# running celestia light node + a Celestia account funded with (testnet) TIA.
# CELESTIA_NODE_URL=http://localhost:26658
# CELESTIA_AUTH_TOKEN=
# CELESTIA_NAMESPACE_HEX=697269732d72637074
